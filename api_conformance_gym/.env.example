# API Conformance Gym Environment Variables Example
# Copy this file to .env and update with your actual values

# =============================================================================
# REQUIRED VARIABLES FOR INFERENCE SCRIPT
# =============================================================================

# LLM API Configuration
API_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-3.5-turbo
API_KEY=sk-your-openai-api-key-here

# Alternative: Hugging Face Inference API
# API_BASE_URL=https://api-inference.huggingface.co/v1
# MODEL_NAME=microsoft/DialoGPT-medium
# HF_TOKEN=hf_your-hugging-face-token-here

# Alternative: Local Ollama
# API_BASE_URL=http://localhost:11434/v1
# MODEL_NAME=llama3.1
# API_KEY=ollama

# =============================================================================
# DOCKER CONFIGURATION (if using containerized environment)
# =============================================================================

IMAGE_NAME=api-conformance-gym:latest

# =============================================================================
# TASK CONFIGURATION (optional - has defaults)
# =============================================================================

API_CONFORMANCE_GYM_TASK=api-design
API_CONFORMANCE_GYM_BENCHMARK=api_conformance_gym

# =============================================================================
# LLM GRADING CONFIGURATION (optional)
# =============================================================================

# Enable LLM-enhanced grading (requires Ollama)
USE_LLM_GRADING=false
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# =============================================================================
# ENVIRONMENT MODE
# =============================================================================

# Options: development, production, hackathon
ENVIRONMENT=development

# =============================================================================
# EXAMPLE CONFIGURATIONS
# =============================================================================

# For OpenAI GPT-4:
# API_BASE_URL=https://api.openai.com/v1
# MODEL_NAME=gpt-4
# API_KEY=sk-your-openai-key

# For Anthropic Claude:
# API_BASE_URL=https://api.anthropic.com/v1
# MODEL_NAME=claude-3-sonnet-20240229
# API_KEY=sk-ant-your-anthropic-key

# For local Ollama with Qwen:
# API_BASE_URL=http://localhost:11434/v1
# MODEL_NAME=qwen2.5:72b-instruct
# API_KEY=ollama